#!/usr/bin/env bash
#
# opencode-memory — Wrapper for OpenCode with post-session memory maintenance.
#
# Installs a shell hook (function) that intercepts the `opencode` command,
# then wraps the real binary with post-session extraction and auto-dream.
#
# Subcommands:
#   opencode-memory install    — Install shell hook to ~/.zshrc or ~/.bashrc
#   opencode-memory uninstall  — Remove shell hook
#   opencode-memory self -v    — Print the wrapper package version
#   opencode-memory [args...]  — Run opencode with post-session memory maintenance
#
# How it works:
#   1. Shell hook defines `opencode()` function that delegates to `opencode-memory`
#   2. `opencode-memory` finds the real `opencode` binary in PATH
#   3. Runs it normally with all your arguments
#   4. After you exit, finds the most recent session
#   5. Optionally runs memory extraction (conversation -> memories)
#   6. Optionally runs auto-dream consolidation (memory pruning/merge)
#
# Requirements:
#   - Real `opencode` CLI reachable in PATH
#   - `jq` for auto-dream gate/session counting
#   - The opencode-memory plugin installed (provides memory_* tools)
#
# Subcommands:
#   install / uninstall            — manage the shell hook
#   maintain [--dir DIR]           — run extraction (+ auto-dream gate) on the
#                                    latest session for DIR without launching an
#                                    interactive opencode (for cron / dashboard
#                                    on_close). Foreground; honours the same
#                                    OPENCODE_MEMORY_* model/bin env vars.
#
# Environment variables:
#   OPENCODE_MEMORY_EXTRACT=0                 — Disable post-session extraction
#   OPENCODE_MEMORY_INCREMENTAL=0             — Disable incremental extraction (re-mine the whole session each resume instead of only new turns)
#   OPENCODE_MEMORY_FOREGROUND=1              — Run maintenance in foreground (debug)
#   OPENCODE_MEMORY_TERMINAL_LOG=1|0          — Force-enable/disable terminal logs (default: foreground only)
#   OPENCODE_MEMORY_OPENCODE_BIN=...          — Path to the opencode binary to use (e.g. a dev build); overrides PATH lookup
#   OPENCODE_MEMORY_MODEL=...                 — Extraction model override
#   OPENCODE_MEMORY_AGENT=...                 — Extraction agent override
#   OPENCODE_MEMORY_AUTODREAM=0               — Disable auto-dream consolidation
#   OPENCODE_MEMORY_AUTODREAM_MIN_HOURS=24    — Min hours between auto-dream runs
#   OPENCODE_MEMORY_AUTODREAM_MIN_SESSIONS=5  — Min touched sessions since last consolidation
#   OPENCODE_MEMORY_AUTODREAM_MODEL=...       — Auto-dream model override
#   OPENCODE_MEMORY_AUTODREAM_AGENT=...       — Auto-dream agent override
#   OPENCODE_MEMORY_DIR=...                   — Override working directory for opencode
#   OPENCODE_MEMORY_LOCAL=auto|on|off         — In-repo memory: on=<repo>/.claude/memory, auto=use it if it exists, off=global store
#   OPENCODE_MEMORY_INDEX_MAX_LINES=160       — Soft MEMORY.md size limit; agent warns once + offers compaction (0/off disables)
#   OPENCODE_MEMORY_LOCAL_SECRETS=0           — Allow secret values in in-repo .claude/memory (default 0: scrubbed; global ~/.claude never scrubbed)
#   OPENCODE_MEMORY_PRINT_SETTINGS=1          — Print resolved extract/dream/recall settings and exit
#
# The extraction/dream model+agent can also be set persistently (without env vars)
# in the plugin `options` block of opencode.json — keys extractModel/extractAgent/
# dreamModel/dreamAgent (recallModel/recallAgent are read in-process by the plugin).
# The in-repo memory switch is likewise read in-process by the plugin (env var
# OPENCODE_MEMORY_LOCAL or opencode.json options.localMemory).
# Precedence: env var > opencode.json options > default (dream falls back to extract).
#

set -euo pipefail

resolve_script_path() {
  if command -v python3 >/dev/null 2>&1; then
    python3 - "${BASH_SOURCE[0]}" <<'PY'
import os
import sys

print(os.path.realpath(sys.argv[1]))
PY
    return 0
  fi

  printf '%s\n' "${BASH_SOURCE[0]}"
}

SCRIPT_PATH="$(resolve_script_path)"
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
PACKAGE_JSON="$SCRIPT_DIR/../package.json"

resolve_package_json() {
  if [ -f "$PACKAGE_JSON" ]; then
    printf '%s\n' "$PACKAGE_JSON"
    return 0
  fi

  if command -v npm >/dev/null 2>&1; then
    local npm_root
    npm_root=$(npm root -g 2>/dev/null || true)
    if [ -n "$npm_root" ] && [ -f "$npm_root/opencode-claude-memory/package.json" ]; then
      printf '%s\n' "$npm_root/opencode-claude-memory/package.json"
      return 0
    fi
  fi

  printf '%s\n' "$PACKAGE_JSON"
}

print_wrapper_version() {
  local version
  local package_json

  package_json="$(resolve_package_json)"

  version=$(awk -F'"' '/^[[:space:]]*"version"[[:space:]]*:/ { print $4; exit }' "$package_json")

  if [ -z "$version" ]; then
    echo "[opencode-memory] ERROR: Cannot read package version from $package_json" >&2
    exit 1
  fi

  printf '%s\n' "$version"
}

# ============================================================================
# Shell Hook Management
# ============================================================================

HOOK_START_MARKER='# >>> opencode-memory auto-initialization >>>'
HOOK_END_MARKER='# <<< opencode-memory auto-initialization <<<'

detect_shell_rc() {
  local shell_name
  shell_name="$(basename "${SHELL:-}")"

  case "$shell_name" in
    zsh)
      echo "$HOME/.zshrc"
      ;;
    bash)
      echo "$HOME/.bashrc"
      ;;
    *)
      if [ -f "$HOME/.zshrc" ]; then
        echo "$HOME/.zshrc"
      elif [ -f "$HOME/.bashrc" ]; then
        echo "$HOME/.bashrc"
      else
        echo "$HOME/.zshrc"
      fi
      ;;
  esac
}

install_hook() {
  local rc_file
  rc_file=$(detect_shell_rc)

  if grep -qF "$HOOK_START_MARKER" "$rc_file" 2>/dev/null; then
    echo "[opencode-memory] Hook already installed in $rc_file"
    return 0
  fi

  cat >> "$rc_file" << 'HOOK'

# >>> opencode-memory auto-initialization >>>
opencode() {
  command opencode-memory "$@"
}
# <<< opencode-memory auto-initialization <<<
HOOK

  echo "[opencode-memory] Shell hook installed in $rc_file"
  echo "[opencode-memory] Restart your shell or run: source $rc_file"
}

remove_hook_from_rc() {
  local rc_file="$1"
  local tmp_file
  tmp_file=$(mktemp)

  awk -v start="$HOOK_START_MARKER" -v end="$HOOK_END_MARKER" '
    $0 == start { skip=1; next }
    $0 == end   { skip=0; next }
    !skip
  ' "$rc_file" > "$tmp_file"

  mv "$tmp_file" "$rc_file"
}

uninstall_hook() {
  local removed=0
  local rc_file

  for rc_file in "$HOME/.zshrc" "$HOME/.bashrc"; do
    [ -f "$rc_file" ] || continue

    if grep -qF "$HOOK_START_MARKER" "$rc_file" 2>/dev/null; then
      remove_hook_from_rc "$rc_file"
      echo "[opencode-memory] Shell hook removed from $rc_file"
      removed=1
    fi
  done

  if [ "$removed" -eq 0 ]; then
    rc_file=$(detect_shell_rc)
    echo "[opencode-memory] Hook not found in $rc_file"
    return 0
  fi

  echo "[opencode-memory] Restart your shell or run: source <your rc file>"
}

# Handle subcommands before any opencode resolution
case "${1:-}" in
  install)
    install_hook
    exit 0
    ;;
  uninstall)
    uninstall_hook
    exit 0
    ;;
  maintain)
    # On-demand maintenance: run extraction (+ the auto-dream gate) on the latest
    # session for a directory WITHOUT launching an interactive opencode. For cron
    # and the session-dashboard on_close hook. Optional: --dir DIR (default: pwd).
    MAINTAIN_MODE=1
    shift
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --dir) OPENCODE_MEMORY_DIR="${2:-}"; shift 2 || shift ;;
        --dir=*) OPENCODE_MEMORY_DIR="${1#--dir=}"; shift ;;
        *) shift ;;
      esac
    done
    [ -n "${OPENCODE_MEMORY_DIR:-}" ] && export OPENCODE_MEMORY_DIR
    set --  # maintain does not forward args to opencode
    ;;
  self)
    case "${2:-}" in
      -v|--version|version)
        print_wrapper_version
        exit 0
        ;;
    esac
    ;;
esac

# ============================================================================
# Resolve the real opencode binary
# ============================================================================

find_real_opencode() {
  # Explicit override wins: point at a specific binary (e.g. a local dev build)
  # without having to reorder PATH. Used for both the wrapped run and the forked
  # extraction/dream invocations.
  if [ -n "${OPENCODE_MEMORY_OPENCODE_BIN:-}" ]; then
    if [ ! -x "$OPENCODE_MEMORY_OPENCODE_BIN" ]; then
      echo "[opencode-memory] ERROR: OPENCODE_MEMORY_OPENCODE_BIN is not an executable file: $OPENCODE_MEMORY_OPENCODE_BIN" >&2
      exit 1
    fi
    echo "$OPENCODE_MEMORY_OPENCODE_BIN"
    return 0
  fi

  # Since this script is named `opencode-memory` (not `opencode`),
  # `command -v opencode` finds the real binary without ambiguity.
  local real
  real=$(command -v opencode 2>/dev/null) || true
  if [ -z "$real" ] || [ ! -x "$real" ]; then
    echo "[opencode-memory] ERROR: Cannot find opencode binary in PATH" >&2
    echo "[opencode-memory] Set OPENCODE_MEMORY_OPENCODE_BIN, or make sure opencode is installed: https://opencode.ai" >&2
    exit 1
  fi
  echo "$real"
}

REAL_OPENCODE="$(find_real_opencode)"

is_opencode_subcommand() {
  case "$1" in
    completion|acp|mcp|attach|run|debug|providers|auth|agent|upgrade|uninstall|serve|web|models|stats|export|import|github|pr|session|plugin|plug|db)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

extract_working_dir_from_args() {
  local previous=""
  for arg in "$@"; do
    if [ "$previous" = "--dir" ]; then
      printf '%s\n' "$arg"
      return 0
    fi
    previous="$arg"
  done

  if [ "$#" -gt 0 ] && [ -n "${1:-}" ] && [[ "${1:-}" != -* ]] && ! is_opencode_subcommand "$1" && [ -d "$1" ]; then
    printf '%s\n' "$1"
    return 0
  fi

  return 1
}

# Read extract/dream model+agent from the plugin `options` block in opencode.json
# (the native per-plugin settings surface). Reads the SAME layered config opencode
# does: global (~/.config/opencode) lowest, then each ancestor dir up to the working
# dir, highest wins; tolerates jsonc (// and /* */ comments + trailing commas) and
# every entry shape ("pkg" | ["pkg",{opts}] | {"package":..,"options":{..}}).
# Prints exactly 4 lines: extractModel, extractAgent, dreamModel, dreamAgent (blank
# when unset). Best-effort — never fails the wrapper. env vars always override these.
read_opencode_plugin_settings() {
  python3 - "${1:-$PWD}" <<'PY' 2>/dev/null
import json, os, re, sys

def strip_jsonc(s):
    out, i, n = [], 0, len(s)
    in_str = esc = False
    while i < n:
        c = s[i]
        if in_str:
            out.append(c)
            if esc: esc = False
            elif c == '\\': esc = True
            elif c == '"': in_str = False
            i += 1; continue
        if c == '"':
            in_str = True; out.append(c); i += 1; continue
        if c == '/' and i + 1 < n and s[i+1] == '/':
            while i < n and s[i] != '\n': i += 1
            continue
        if c == '/' and i + 1 < n and s[i+1] == '*':
            i += 2
            while i + 1 < n and not (s[i] == '*' and s[i+1] == '/'): i += 1
            i += 2; continue
        out.append(c); i += 1
    return re.sub(r',(\s*[}\]])', r'\1', ''.join(out))

KEYS = ("extractModel", "extractAgent", "dreamModel", "dreamAgent")
resolved = {k: "" for k in KEYS}

def absorb(opts):
    if isinstance(opts, dict):
        for k in KEYS:
            v = opts.get(k)
            if isinstance(v, str) and v.strip():
                resolved[k] = v.strip()

def scan(cfg):
    if not isinstance(cfg, dict): return
    entries = []
    for key in ("plugin", "plugins"):
        v = cfg.get(key)
        if isinstance(v, list): entries.extend(v)
    for e in entries:
        if isinstance(e, dict):
            absorb(e.get("options"))
        elif isinstance(e, list) and len(e) >= 2:   # ["pkg", {options}] tuple form
            absorb(e[1])

try:
    wd = os.path.abspath(sys.argv[1] if len(sys.argv) > 1 else os.getcwd())
    xdg = os.environ.get("XDG_CONFIG_HOME") or os.path.join(os.path.expanduser("~"), ".config")
    dirs = [os.path.join(xdg, "opencode")]           # global, lowest priority
    anc, cur = [], wd
    while True:
        anc.append(cur)
        parent = os.path.dirname(cur)
        if parent == cur: break
        cur = parent
    dirs += list(reversed(anc))                      # root .. working dir, highest last
    for d in dirs:
        for name in ("config.json", "opencode.json", "opencode.jsonc"):
            try:
                with open(os.path.join(d, name), encoding="utf-8") as f:
                    raw = f.read()
            except OSError:
                continue
            try:
                scan(json.loads(strip_jsonc(raw)))
            except Exception:
                continue
except Exception:
    pass

sys.stdout.write("\n".join(resolved[k] for k in KEYS) + "\n")
PY
}

# ============================================================================
# Configuration
# ============================================================================

EXTRACT_ENABLED="${OPENCODE_MEMORY_EXTRACT:-1}"
# Incremental extraction: persist a per-session high-water mark (user-turn count at
# last successful extraction) so resuming a session re-mines only the NEW turns
# instead of re-forking the whole conversation. 0 reverts to full re-extraction.
INCREMENTAL_ENABLED="${OPENCODE_MEMORY_INCREMENTAL:-1}"
FOREGROUND="${OPENCODE_MEMORY_FOREGROUND:-0}"
LOG_ENABLED="${OPENCODE_MEMORY_TERMINAL_LOG:-}"
EXTRACT_MODEL="${OPENCODE_MEMORY_MODEL:-}"
EXTRACT_AGENT="${OPENCODE_MEMORY_AGENT:-}"
# user-profile memories are OPT-IN (default off): a hand-built gold-standard store
# for a focused project carried zero of them. Credential *pointers* (references to
# where secrets live, never the values) are OPT-OUT (default allowed): that is how
# the user actually tracks where creds are.
CAPTURE_USER="${OPENCODE_MEMORY_CAPTURE_USER:-0}"
REDACT_CRED_POINTERS="${OPENCODE_MEMORY_REDACT_CRED_POINTERS:-0}"

AUTODREAM_ENABLED="${OPENCODE_MEMORY_AUTODREAM:-1}"
AUTODREAM_MIN_HOURS="${OPENCODE_MEMORY_AUTODREAM_MIN_HOURS:-24}"
AUTODREAM_MIN_SESSIONS="${OPENCODE_MEMORY_AUTODREAM_MIN_SESSIONS:-5}"
AUTODREAM_SCAN_LIMIT="${OPENCODE_MEMORY_AUTODREAM_SCAN_LIMIT:-200}"
# env layer only here; opencode.json fill + the extract-model fallback are applied
# below, once WORKING_DIR is known (so dream precedence is env > opencode.json > extract).
AUTODREAM_MODEL="${OPENCODE_MEMORY_AUTODREAM_MODEL:-}"
AUTODREAM_AGENT="${OPENCODE_MEMORY_AUTODREAM_AGENT:-}"
AUTODREAM_STALE_LOCK_SECS=$((60 * 60))
SESSION_WAIT_SECONDS="${OPENCODE_MEMORY_SESSION_WAIT_SECONDS:-5}"

WORKING_DIR="${OPENCODE_MEMORY_DIR:-$(extract_working_dir_from_args "$@" || pwd)}"

# Fill any model/agent the environment did not set from the opencode.json plugin
# `options` block (the native settings surface). env always wins; dream falls back
# to the extract model (preserving prior behavior) when neither env nor opencode.json
# specifies one. Precedence: env > opencode.json options > (dream: the extract model).
if [ -z "$EXTRACT_MODEL" ] || [ -z "$EXTRACT_AGENT" ] || [ -z "$AUTODREAM_MODEL" ] || [ -z "$AUTODREAM_AGENT" ]; then
  # `|| true` on each read so an EOF (e.g. python3 missing → no output) does not
  # trip `set -e`; the vars simply stay empty and we fall back to defaults.
  { IFS= read -r _cfg_extract_model || true
    IFS= read -r _cfg_extract_agent || true
    IFS= read -r _cfg_dream_model || true
    IFS= read -r _cfg_dream_agent || true
  } < <(read_opencode_plugin_settings "$WORKING_DIR") || true
  EXTRACT_MODEL="${EXTRACT_MODEL:-$_cfg_extract_model}"
  EXTRACT_AGENT="${EXTRACT_AGENT:-$_cfg_extract_agent}"
  AUTODREAM_MODEL="${AUTODREAM_MODEL:-${_cfg_dream_model:-$EXTRACT_MODEL}}"
  AUTODREAM_AGENT="${AUTODREAM_AGENT:-${_cfg_dream_agent:-$EXTRACT_AGENT}}"
  unset _cfg_extract_model _cfg_extract_agent _cfg_dream_model _cfg_dream_agent
fi

# Verify resolved settings (env + opencode.json) without launching a session.
if [ "${OPENCODE_MEMORY_PRINT_SETTINGS:-0}" = "1" ]; then
  printf 'opencode.bin=%s\nextract.model=%s\nextract.agent=%s\nextract.incremental=%s\ndream.model=%s\ndream.agent=%s\nrecall.model=%s\nlocal.mode=%s\nlocal.secrets=%s\nindex.max_lines=%s\n' \
    "$REAL_OPENCODE" \
    "${EXTRACT_MODEL:-<opencode default>}" "${EXTRACT_AGENT:-<opencode default>}" \
    "${OPENCODE_MEMORY_INCREMENTAL:-1}" \
    "${AUTODREAM_MODEL:-<opencode default>}" "${AUTODREAM_AGENT:-<opencode default>}" \
    "${OPENCODE_MEMORY_RECALL_MODEL:-<opencode.json options.recallModel, else default>}" \
    "${OPENCODE_MEMORY_LOCAL:-<opencode.json options.localMemory, else auto>}" \
    "${OPENCODE_MEMORY_LOCAL_SECRETS:-<opencode.json options.localMemorySecrets, else off>}" \
    "${OPENCODE_MEMORY_INDEX_MAX_LINES:-<opencode.json options.indexMaxLines, else 160>}"
  exit 0
fi

TMP_BASE_DIR="${TMPDIR:-/tmp}"
while [ "$TMP_BASE_DIR" != "/" ] && [ "${TMP_BASE_DIR%/}" != "$TMP_BASE_DIR" ]; do
  TMP_BASE_DIR="${TMP_BASE_DIR%/}"
done
if [ -z "$TMP_BASE_DIR" ]; then
  TMP_BASE_DIR="/"
fi

# Scope lock files at project root granularity (not per-subdirectory).
PROJECT_SCOPE_DIR="$WORKING_DIR"
if git -C "$WORKING_DIR" rev-parse --show-toplevel >/dev/null 2>&1; then
  PROJECT_SCOPE_DIR="$(git -C "$WORKING_DIR" rev-parse --show-toplevel 2>/dev/null || echo "$WORKING_DIR")"
fi

PROJECT_KEY="$(printf '%s' "$PROJECT_SCOPE_DIR" | cksum | awk '{print $1}')"

# Lock files (prevent concurrent work on the same project)
LOCK_DIR="$TMP_BASE_DIR/opencode-memory-locks"
mkdir -p "$LOCK_DIR"
EXTRACT_LOCK_FILE="$LOCK_DIR/${PROJECT_KEY}.extract.lock"

STATE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/opencode-memory"
mkdir -p "$STATE_DIR"
CONSOLIDATION_LOCK_FILE="$STATE_DIR/${PROJECT_KEY}.consolidate-lock"

# Logs
LOG_DIR="$TMP_BASE_DIR/opencode-memory-logs"
mkdir -p "$LOG_DIR"
TASK_LOG_PREFIX="$(date +%Y%m%d-%H%M%S)-${PROJECT_KEY}"
EXTRACT_LOG_FILE="$LOG_DIR/extract-${TASK_LOG_PREFIX}.log"
AUTODREAM_LOG_FILE="$LOG_DIR/dream-${TASK_LOG_PREFIX}.log"

# ============================================================================
# Prompts
# ============================================================================

# Adapted from Claude Code's extraction prompt, simplified for OpenCode's
# headless run mode. The model sees the full conversation context via --fork.
EXTRACT_PROMPT='You are the post-session extraction subagent. Work in TWO ORDERED PHASES over the conversation above. The phases capture different things into different sinks. Do Phase 1 first, then Phase 2.

# Phase 1 — Harness feedback (do this FIRST, before any memory)

Scan the conversation for observations about how the AGENT, its SKILLS, or its TOOLS behaved, or about how the harness itself should change. These are feedback for the harness developer: the fix is a diff to a system prompt, an agent config, or a skill — NOT a fact the agent recalls next session. Record each with the `harness_feedback` tool (category: tool-efficiency | agent-behavior | skill-design | harness-config | other).

Record harness feedback when you see:
- tool-use inefficiency: redundant file reads, retry loops, errors not surfacing to the agent, thrashing
- a skill or tool that under-performed: one that only DESCRIBED what to do instead of acting, a missing background/watcher loop, polling too slowly, an unclear tool description, a behavior the user had to correct more than once
- anything whose fix belongs in a prompt, config, or skill rather than in per-session memory — but ONLY when triggered by an inefficiency or misbehavior you OBSERVED the agent exhibit this session, never as a code-review opinion about code the session was discussing

Strong signal: places where the user corrected the agent repeatedly, or was frustrated that the agent or a skill was not doing what it should. Those corrections are harness feedback, NOT user preferences and NOT memory.

If Phase 1 finds nothing, record nothing and move on. That is common and fine.

PHASE-1 OBSERVATION RULE: harness_feedback must describe behavior that ACTUALLY OCCURRED in THIS conversation — a specific tool call, retry loop, surfaced error, or user correction you can point to in the transcript above. Cite that observed event in the content. Do NOT record a hypothesized, would-be-better, or merely suggested improvement, and do NOT fabricate a plausible fix: if you cannot point to the turn or tool call where the problem actually happened, record nothing. When the conversation SUBJECT is agent, harness, skill, or tooling code (a review, design, or discussion session), that subject matter is NOT harness_feedback — review opinions about the code under discussion are the session deliverable, not feedback about how the agent behaved while running it. Default to recording nothing; zero harness_feedback is the common and expected outcome.

EXAMPLES.
- DO record: Agent re-ran the same `grep` over one file across turns 4/7/9 because results were not retained — tool-efficiency (an event in the transcript).
- DO NOT record: memory_save filename validation is strict; the error should suggest a flat filename (a code-review suggestion about code under discussion — no observed agent misbehavior; this is fabricated harness feedback).

# Phase 2 — Memory (durable facts only)

Now extract durable facts worth recalling in FUTURE sessions, with `memory_save`. Four types:

1. **user** — Who the user is: role, expertise, domain, stable working preferences. DISABLED BY DEFAULT: do NOT save `user` memories unless a USER-CAPTURE line near the end of this prompt explicitly enables them. Absent that line, skip type=user entirely — even when the role is obvious. (A gold-standard hand-built store for a focused project carried zero user memories; they are low-value noise here unless the user opts in.)
2. **feedback** — A standing preference for how to COLLABORATE with this user on this project (e.g. terse replies, bundle PRs, run tests before pushing). Include *why*.
3. **project** — Ongoing work context: goals, deadlines, decisions, bugs. NOT derivable from code/git. Convert relative dates to absolute.
4. **reference** — Pointers to external resources: URLs, tool names, config locations, where to find things outside the codebase.

Hard-to-rederive beats strictly-absent-from-disk. DO save a `reference` or `project` memory for a fact that is technically in the code or config but would be PAINFUL to rediscover: a non-obvious feature-flag env var (such as an OPENCODE_EXPERIMENTAL_* gate), a global-config wiring that an agent working in a different repo would never think to read, or a cross-cutting setup step. Restraint means skipping junk and redundancy, not skipping a clean non-obvious fact. The memory bar is: durable AND useful AND not already in a doc/SKILL/config the user will open anyway.

In Phase 2 do NOT analyze agent, skill, tool, or harness behavior — that was Phase 1. If a finding is about how the agent or a skill should be BUILT or should BEHAVE, it is harness_feedback, not a `feedback` memory.

EVIDENCE RULE (user and feedback types): save it only if you can quote the specific user turn that proves it, and put a short quote in the content. If the user never stated or demonstrated it — if you are inferring it from one task or from watching the agent work — do NOT save it. A benchmark of three providers is not a provider preference. Terse phrasing in one session is not a stated communication style unless the user asked for terseness.

ATTRIBUTION RULE (whose words are these): the conversation above includes reasoning/thinking blocks the agent produced and assistant messages — not only user turns. Treat reasoning and assistant text as output FROM the agent: legitimate input for Phase 1 when judging how the agent behaved, but NEVER a user statement. Do not quote, paraphrase, or attribute reasoning, an assistant message, a tool result, or a summary the agent itself wrote as if the user said it. A `user` or `feedback` memory, and any quoted evidence, must come from a real USER turn that appears verbatim above; if you cannot point to that actual user turn, the EVIDENCE RULE is not met — do not save. Never manufacture a quote: a quoted sentence that does not appear verbatim in a user turn is a fabrication, even if it captures the gist.

EXPLICIT-DIRECTIVE RULE (honors a deliberate request; overrides the user-capture default-off, never the redaction or junk rules): when the user issues a direct memory directive in the conversation — "remember that X", "remember I am X", "always do/check X", "never do X", "from now on X" — that turn IS the evidence. Save it as the best-fit type and quote the directive; the EVIDENCE RULE is satisfied by the directive itself, so a single explicit turn is enough (this is a stated preference, not an inference from one task). A direct directive PIERCES the USER-CAPTURE default-off: "remember I am a Go engineer" is an explicit request, not an inferred profile, so save it as type=user even when no USER-CAPTURE line is present or a line says DISABLED — the opt-in suppresses GUESSING a user profile, not honoring a request to store one. Distinguish this from an incidental aside: a user who merely mentions their background in passing is still suppressed; only a save directive pierces. The directive does NOT pierce the REDACTION RULE or the "What NOT to save" exclusions: an explicit "remember this token" or "save the PR list" is still refused — record only a location pointer, or capture only what was non-obvious. The override exists to honor a deliberate ask, never to store a secret value or derivable junk.

REDACTION RULE: never write secret VALUES — no API keys, key prefixes, tokens, passwords, or any material that grants access. That part is absolute. You MAY, however, record a credential REFERENCE: a pointer to WHERE credentials live (e.g. a `reference` memory noting an endpoint requires basic auth and its creds are in `~/.cron-dash-creds`, or that a deploy key lives at `~/.cronicle-deploy-key`). A reference names the location only, never the secret — do not quote a password, do not write the password value, do not copy the contents of a creds file. If a CRED-POINTER line near the end of this prompt says pointers are DISABLED, also omit credential file locations and usernames; otherwise a location reference is allowed (it is how the user actually tracks where secrets live). When unsure about a VALUE, omit it.

PROVENANCE RULE (project memories about code changes): anchor the memory in durable provenance, do not leave it vague. If a COMMITS block is provided in this message, cite the commit hash whose timestamp and changed files match the change you are describing; include the key `file:line` references that appear in the tool calls (e.g. `mppt.cpp:217`). A memory that says "fixed the timer wrap" is weak; "fixed in <commit> — wallClockUs() now 64-bit, mppt.cpp:217" (replace <commit> with the REAL hash from the COMMITS block) is durable and rederivable. If NO COMMITS block appears in this message, still save the memory — anchor it on the file:line references from the tool calls and OMIT the hash; do NOT write any commit hash, never copy the literal placeholder <commit>, and never reuse a hash from this prompt or from another session. Never invent a hash or a line number — cite only what the COMMITS block or the tool calls actually contain.

ONE-FACT RULE: each memory is ONE independently-retrievable fact — the unit a future agent would recall on its own. If a session surfaced several distinct durable facts, save several memories, not one bundle. Test by retrieval intent: if two parts would be surfaced by DIFFERENT questions, they are different memories — e.g. "how do I build?", "where do the creds live?", "how do I OTA a device?", and "what are the live device names?" are four memories, not one "ops tools" file. Do NOT over-split a single coherent fact, though: a fix made of coordinated commits, or a fact with its **Why:** / **How to apply:**, is ONE memory. Make each `description` specific enough to match on its own.

## What NOT to save as memory
- Code patterns, architecture, file structure — derivable from the codebase
- Git history, recent changes — use `git log`/`git blame`
- Debugging solutions — the fix is in the code
- Anything already in AGENTS.md, project config, a design doc, or a SKILL.md the user will reference — point to it at most, do not restate it
- Ephemeral task details or current conversation context
- Information already saved in a previous extraction
- The design, architecture, file-format, or STORAGE LOCATION of ANY memory, notes, or knowledge system — INCLUDING a memory or notes system being designed in this very session, and INCLUDING where the memory files themselves live (a `.claude/` layout, a symlink chain, that memory is git-tracked). That lives in its own design doc, never in memory. Do not save "how memory files are formatted", "the auto-memory pipeline design", "project memory lives under `.claude/`", or a memory about this extraction process itself. (A credential or config LOCATION the user keeps in the repo is NOT this — where secrets live is a `reference` pointer, per the REDACTION RULE, not a `feedback` memory.)

## How to save a memory
Call `memory_save` with: `file_name` (slug, e.g. `user_role`), `name` (short title), `description` (one-line, for relevance matching), `type` (user|feedback|project|reference), `content`. For feedback/project, structure the content as the rule/fact then **Why:** and **How to apply:** lines; for user/feedback, include the quoted evidence. Check `memory_list` first and update an existing entry instead of duplicating. You MAY link a related memory inline in the content with `[[file-name]]`, but ONLY using a file_name that appears VERBATIM in your `memory_list` output this session — do NOT construct, guess, or recall a slug from the topic, from another project, or from memory. If the related entry is not in `memory_list`, do not link it (the link graph fills in as the store grows). When unsure a slug exists, omit the link. Link only genuine relationships.

# Calibration
Be selective but not empty-handed. Many sessions warrant zero memories and that is fine — but a session that surfaced a clean, non-obvious, durable fact should save it. Skip junk, redundancy, projections, and ungrounded inferences; keep genuine signal. Do not invent a memory just because you were asked to extract, and do not suppress a good one just to be safe.'

# Append the runtime capture directives the prompt body refers to. user-profile
# capture is opt-in (default off); credential-location references are opt-out
# (default allowed — secret VALUES are never written regardless). The replay
# harness parses the static EXTRACT_PROMPT above and so sees neither line, which
# the prompt body resolves to exactly these defaults (user off, cred-pointer on).
if [ "$CAPTURE_USER" = "1" ]; then
  EXTRACT_PROMPT+=$'\n\nUSER-CAPTURE: ENABLED — you may save `user` memories when the EVIDENCE RULE is met.'
else
  EXTRACT_PROMPT+=$'\n\nUSER-CAPTURE: DISABLED — do not save any type=user memories in this run.'
fi
if [ "$REDACT_CRED_POINTERS" = "1" ]; then
  EXTRACT_PROMPT+=$'\nCRED-POINTER: DISABLED — omit credential file locations and usernames too (secret values are always omitted regardless).'
else
  EXTRACT_PROMPT+=$'\nCRED-POINTER: ENABLED — a credential location reference is allowed; secret values are never written.'
fi

# Periodic memory consolidation inspired by Claude Code auto-dream.
AUTODREAM_PROMPT="$(cat <<'EOF'
You are performing a dream — a small pruning pass over this project's memory files. The job is narrow: delete stale or invalidated memories, and collapse duplicates. Do NOT mass-rewrite, re-summarise, or "improve" memories that are already fine — a clean memory set is a valid outcome.

## Tools — use ONLY these
The memory store does NOT live in your working directory. The builtin file tools (read, write, edit, bash, grep, glob) CANNOT reach it and will error — operate exclusively through the memory_* tools below, addressing every memory by the file_name shown in memory_list (never by a filesystem path).
- memory_list   — inventory every memory (name, type, created date, description)
- memory_search — find memories by keyword
- memory_read   — read one memory's full body and its `created` timestamp (pass its file_name, NOT a path)
- memory_save   — write a fresh memory file (pass `created` to preserve an older date)
- memory_delete — remove a memory file by its file_name

Work the whole inventory to completion in this one pass: read, decide, and apply your deletes/saves directly. Do not stop after planning, and do not ask for confirmation — there is no user to answer.

## Memory files are immutable
Never edit a memory in place. To combine memories you DELETE the old files and, only if a single replacement is warranted, memory_save ONE fresh file. Each memory file holds exactly one fact — never fold unrelated facts into a multi-fact file to save space.

## The pass
1. memory_list to see the whole inventory. For any cluster that looks overlapping, memory_read each member before touching it — descriptions alone are not enough to merge on.
2. For each memory, decide:
   - **Stale / invalidated** — the fact no longer holds (contradicted by a newer memory, the project moved on, a preference changed). memory_delete it.
   - **Duplicate / near-duplicate** — another memory already covers the same fact. Delete the redundant copies. If one richer single-fact memory would genuinely replace the cluster, memory_delete the whole cluster and memory_save one fresh file in its place. When you write that replacement, pass `created` = the OLDEST source memory's `created` value so the manifest sort order stays accurate.
   - **Still good** — leave it untouched.

## Discipline (carry over from how memories are saved)
- Only collapse memories of the SAME type. A `user` profile, a `feedback` rule, a `project` fact and a `reference` pointer are different kinds — never fold one into another.
- A combined memory may state only what its sources already established — do NOT invent, infer, or escalate a claim while merging.
- Never introduce a credential value, file, path, or username pointer that the sources did not already contain; if a source leaks one, drop that detail rather than copying it forward.
- Do not create a memory ABOUT the memory / notes system itself.
- Keep each surviving description specific enough to retrieve on.

## Guardrails
- When confidence is low, KEEP the existing memory rather than guessing.
- Never delete the last copy of a fact you cannot find recorded elsewhere.
- If the memory set is already clean, change nothing and say so explicitly.

Return a brief summary: what you deleted, what you combined (and into what), and what you left alone. If nothing changed, say so.
EOF
)"

# ============================================================================
# Helper Functions
# ============================================================================

should_log() {
  if [ -n "$LOG_ENABLED" ]; then
    [ "$LOG_ENABLED" = "1" ]
    return $?
  fi

  [ "$FOREGROUND" = "1" ]
}

log() {
  should_log || return 0
  echo "[opencode-memory] $*" >&2
}

is_positive_int() {
  [[ "$1" =~ ^[0-9]+$ ]] && [ "$1" -gt 0 ]
}

is_bool_flag() {
  [ "$1" = "0" ] || [ "$1" = "1" ]
}

if [ -n "$LOG_ENABLED" ] && ! is_bool_flag "$LOG_ENABLED"; then
  echo "[opencode-memory] Invalid OPENCODE_MEMORY_TERMINAL_LOG=$LOG_ENABLED, expected 0 or 1; defaulting to foreground-only logging" >&2
  LOG_ENABLED=""
fi

if ! is_positive_int "$AUTODREAM_MIN_HOURS"; then
  log "Invalid OPENCODE_MEMORY_AUTODREAM_MIN_HOURS=$AUTODREAM_MIN_HOURS, using default 24"
  AUTODREAM_MIN_HOURS=24
fi
if ! is_positive_int "$AUTODREAM_MIN_SESSIONS"; then
  log "Invalid OPENCODE_MEMORY_AUTODREAM_MIN_SESSIONS=$AUTODREAM_MIN_SESSIONS, using default 5"
  AUTODREAM_MIN_SESSIONS=5
fi
if ! is_positive_int "$AUTODREAM_SCAN_LIMIT"; then
  log "Invalid OPENCODE_MEMORY_AUTODREAM_SCAN_LIMIT=$AUTODREAM_SCAN_LIMIT, using default 200"
  AUTODREAM_SCAN_LIMIT=200
fi

has_new_memories() {
  # Check if any memory file was modified during the session.
  local mem_base="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/projects"
  if [ ! -d "$mem_base" ]; then
    return 1
  fi

  local newer_files
  newer_files=$(find "$mem_base" -path "*/memory/*.md" -newer "$TIMESTAMP_FILE" 2>/dev/null | head -1)
  [ -n "$newer_files" ]
}

cleanup_timestamp() {
  rm -f "$TIMESTAMP_FILE" "${TRANSCRIPT_CHECKPOINT_FILE:-}"
}

get_session_list_json() {
  local limit="$1"
  local output

  if output=$("$REAL_OPENCODE" session list --format json -n "$limit" 2>/dev/null); then
    echo "$output"
    return 0
  fi

  if output=$("$REAL_OPENCODE" session list --format json 2>/dev/null); then
    echo "$output"
    return 0
  fi

  return 1
}

get_latest_session_id() {
  local session_json
  session_json=$(get_session_list_json 1) || return 1

  # Parse with jq if available, fallback to grep.
  if command -v jq &>/dev/null; then
    echo "$session_json" | jq -r '.[0].id // empty'
  else
    echo "$session_json" | grep -o '"id"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)"/\1/'
  fi
}

get_opencode_db_path() {
  # Honour OPENCODE_DB (the binary's own resolution): a bare/relative name lives
  # under the opencode data dir, an absolute path is used as-is. Without this the
  # direct-SQLite helpers (titles, commit provenance, fork cleanup) would read the
  # wrong DB when a launcher pins e.g. OPENCODE_DB=opencode-dev.db.
  local data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/opencode"
  local db="${OPENCODE_DB:-opencode.db}"
  case "$db" in
    /*) printf '%s\n' "$db" ;;
    *)  printf '%s\n' "$data_dir/$db" ;;
  esac
}

get_session_title_from_db() {
  local session_id="$1"
  local db_path
  db_path=$(get_opencode_db_path)

  if [ -z "$session_id" ] || [ ! -f "$db_path" ] || ! command -v python3 >/dev/null 2>&1; then
    return 1
  fi

  python3 - "$db_path" "$session_id" <<'PY'
import sqlite3
import sys

db_path, session_id = sys.argv[1:3]

try:
    conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    row = conn.execute("SELECT title FROM session WHERE id = ? LIMIT 1", (session_id,)).fetchone()
except Exception:
    raise SystemExit(1)
finally:
    try:
        conn.close()
    except Exception:
        pass

if row and row[0]:
    print(row[0])
PY
}

# Recover the commit-hash provenance the forked extractor otherwise lacks: the
# fork replays the real tool calls (so file:line is already visible), but a
# commit made at/after the conversation may not show its hash in any tool output.
# So we git-log every repo the session touched (the working dir PLUS any nested
# checkout a touched file lives in) over the session's time window, and print a
# hash + time + changed-files block to prepend to the extract prompt. The
# PROVENANCE RULE then tells the model to cite a matching hash (never invent one).
# Read-only; prints nothing (=> no block injected) on any error or empty result.
get_session_commits_block() {
  local session_id="$1"
  local working_dir="$2"
  local db_path
  db_path=$(get_opencode_db_path)

  if [ -z "$session_id" ] || [ -z "$working_dir" ] || [ ! -f "$db_path" ] || ! command -v python3 >/dev/null 2>&1; then
    return 1
  fi

  python3 - "$db_path" "$session_id" "$working_dir" <<'PY'
import sqlite3, sys, os, json, subprocess
from datetime import datetime

db_path, session_id, directory = sys.argv[1:4]
MAX_PROVENANCE_REPOS, MAX_REPO_PROBE_DIRS, MAX_COMMITS = 4, 40, 40
PAD_MIN, PAD_AFTER_MIN = 5, 90

def done():  # print nothing, exit clean -> caller injects no block
    raise SystemExit(0)

# session time window + touched files, from the part table
try:
    conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    rows = conn.execute(
        "SELECT time_created, json_extract(data,'$.type'), json_extract(data,'$.state.input') "
        "FROM part WHERE session_id = ?", (session_id,)).fetchall()
except Exception:
    done()
finally:
    try: conn.close()
    except Exception: pass

t_min = t_max = None
touched, tseen = [], set()
for tms, ptype, inp in rows:
    if tms:
        t_min = tms if t_min is None else min(t_min, tms)
        t_max = tms if t_max is None else max(t_max, tms)
    if ptype == "tool" and inp:
        try: d = json.loads(inp)
        except Exception: continue
        for k in ("filePath", "file_path", "path", "file"):
            v = d.get(k)
            if isinstance(v, str) and v and v not in tseen:
                tseen.add(v); touched.append(v); break
if t_min is None or t_max is None:
    done()

# nearest-.git work-tree root above a path (nesting-correct, stat-only, memoized)
_cache = {}
def toplevel(start):
    if not start: return ""
    d = start if os.path.isdir(start) else os.path.dirname(start)
    chain = []
    while d and d not in _cache:
        chain.append(d)
        if os.path.exists(os.path.join(d, ".git")):
            root = os.path.realpath(d)
            for c in chain: _cache[c] = root
            return root
        parent = os.path.dirname(d)
        if parent == d: break
        d = parent
    root = _cache.get(d, "")
    for c in chain: _cache[c] = root
    return root

# distinct repos the session touched, working dir first (its commits are primary)
roots, seen = [], set()
def add(start):
    top = toplevel(start)
    if top and top not in seen:
        seen.add(top); roots.append(top)
add(directory)
probed = set()
for f in touched:
    dd = f if os.path.isdir(f) else os.path.dirname(f)
    if not dd or dd in probed: continue
    probed.add(dd)
    if len(probed) > MAX_REPO_PROBE_DIRS: break
    add(dd)
repos = roots[:MAX_PROVENANCE_REPOS]
if not repos:
    done()

since = datetime.fromtimestamp(t_min/1000 - PAD_MIN*60).strftime("%Y-%m-%d %H:%M:%S")
until = datetime.fromtimestamp(t_max/1000 + PAD_AFTER_MIN*60).strftime("%Y-%m-%d %H:%M:%S")

def log_entries(repo, limit):
    try:
        out = subprocess.run(
            ["git", "-C", repo, "log", f"--since={since}", f"--until={until}",
             f"--max-count={limit}", "--no-merges",
             "--pretty=format:%h\t%ad\t%s", "--date=format:%Y-%m-%d %H:%M:%S", "--name-only"],
            capture_output=True, text=True, timeout=30)
    except Exception:
        return []
    if out.returncode != 0 or not out.stdout.strip():
        return []
    entries, header, cur = [], None, []
    def flush():
        if header:
            h, dt, s = header
            files = ", ".join(cur[:12]) + (" …" if len(cur) > 12 else "")
            entries.append((h, f"- {h}  {dt}  {s}" + (f"\n    files: {files}" if files else "")))
    for ln in out.stdout.splitlines():
        if ln.count("\t") >= 2:
            flush(); p = ln.split("\t", 2); header, cur = (p[0], p[1], p[2]), []
        elif ln.strip():
            cur.append(ln.strip())
    flush()
    return entries

seen_h, sections, n = set(), [], 0
label = len(repos) > 1
for repo in repos:
    if n >= MAX_COMMITS: break
    fresh = [(h, e) for (h, e) in log_entries(repo, MAX_COMMITS - n) if h not in seen_h]
    if not fresh: continue
    seen_h.update(h for h, _ in fresh); n += len(fresh)
    body = "\n".join(e for _, e in fresh)
    sections.append((f"### repo: {repo}\n" if label else "") + body)
if not sections:
    done()

print("## Commits in this session (use to anchor project memories)")
print("Match a memory's code change to the commit whose time and changed files fit, "
      "and cite its hash. Do not cite a commit that does not match.")
print()
print("\n\n".join(sections))
PY
}

get_session_target_id() {
  local before_json="$1"
  local started_at_ms="$2"
  local workdir="$3"
  local project_dir="$4"
  local allow_existing_fallback="${5:-1}"
  local after_json

  after_json=$(get_session_list_json "$AUTODREAM_SCAN_LIMIT") || return 1

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$before_json" "$after_json" "$started_at_ms" "$workdir" "$project_dir" "$allow_existing_fallback" <<'PY'
import json
import os
import sys

before_raw, after_raw, started_at_ms_raw, workdir, project_dir, allow_existing_fallback_raw = sys.argv[1:7]

def parse(raw):
    try:
        data = json.loads(raw)
        return data if isinstance(data, list) else []
    except Exception:
        return []

def timestamp(item):
    time_obj = item.get("time") if isinstance(item.get("time"), dict) else {}
    for key in ("updated", "created"):
        value = item.get(key)
        if value is not None:
            try:
                return int(value)
            except Exception:
                pass
        value = time_obj.get(key)
        if value is not None:
            try:
                return int(value)
            except Exception:
                pass
    return 0

def normalize(path):
    if not path:
        return ""
    return os.path.realpath(path)

before = parse(before_raw)
after = parse(after_raw)
started_at_ms = int(started_at_ms_raw or "0")
allow_existing_fallback = allow_existing_fallback_raw == "1"
before_ids = {item.get("id") for item in before if item.get("id")}
workdir = normalize(workdir)
project_dir = normalize(project_dir)

def in_scope(item):
    directory = normalize(item.get("directory", ""))
    return directory != "" and directory in {workdir, project_dir}

def choose(candidates):
    ranked = sorted(
        [item for item in candidates if item.get("id")],
        key=lambda item: timestamp(item),
        reverse=True,
    )
    if ranked:
        print(ranked[0]["id"])
        return True
    return False

new_sessions = [item for item in after if item.get("id") not in before_ids]
updated_sessions = [item for item in after if timestamp(item) > started_at_ms]

candidate_pools = [
    [item for item in new_sessions if in_scope(item)],
    [item for item in updated_sessions if in_scope(item)],
]

if allow_existing_fallback:
    candidate_pools.append([item for item in after if in_scope(item)])

for pool in candidate_pools:
    if choose(pool):
        break
PY
    return 0
  fi

  get_latest_session_id
}

get_transcripts_dir() {
  printf '%s\n' "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/transcripts"
}

get_storage_session_diff_dir() {
  printf '%s\n' "$HOME/.local/share/opencode/storage/session_diff"
}

resolve_session_directory() {
  local session_id="$1"
  local output_file

  output_file=$(mktemp)
  if ! "$REAL_OPENCODE" export "$session_id" >"$output_file" 2>/dev/null; then
    rm -f "$output_file"
    return 1
  fi

  if [ ! -s "$output_file" ]; then
    rm -f "$output_file"
    return 1
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$output_file" <<'PY'
import json
from pathlib import Path
import sys

raw = Path(sys.argv[1]).read_text()
start = raw.find('{')
if start == -1:
    raise SystemExit(1)

try:
    data = json.loads(raw[start:])
except Exception:
    raise SystemExit(1)

directory = ((data.get("info") or {}).get("directory") or "")
if directory:
    print(directory)
PY
    local status=$?
    rm -f "$output_file"
    return $status
  fi

  rm -f "$output_file"
  return 1
}

get_scoped_artifact_session_id_since() {
  local timestamp_file="$1"
  local workdir="$2"
  local project_dir="$3"

  if ! command -v python3 >/dev/null 2>&1; then
    return 1
  fi

  local candidates
  candidates=$(python3 - "$timestamp_file" "$HOME" "${CLAUDE_CONFIG_DIR:-$HOME/.claude}" <<'PY'
import os
import sys

timestamp_file, home_dir, claude_dir = sys.argv[1:4]

try:
    threshold = os.path.getmtime(timestamp_file)
except OSError:
    raise SystemExit(1)

sources = [
    (os.path.join(home_dir, '.local', 'share', 'opencode', 'storage', 'session_diff'), '.json'),
    (os.path.join(claude_dir, 'transcripts'), '.jsonl'),
]

latest = {}
for directory, suffix in sources:
    if not os.path.isdir(directory):
        continue
    for entry in os.scandir(directory):
        if not entry.is_file() or not entry.name.endswith(suffix):
            continue
        try:
            mtime = entry.stat().st_mtime
        except OSError:
            continue
        if mtime <= threshold:
            continue
        session_id = entry.name[:-len(suffix)]
        latest[session_id] = max(latest.get(session_id, -1), mtime)

for session_id, mtime in sorted(latest.items(), key=lambda item: item[1], reverse=True):
    print(session_id)
PY
  ) || return 1

  local session_id=""
  local session_dir=""
  local normalized_session_dir=""
  local normalized_workdir=""
  local normalized_project_dir=""
  normalized_workdir=$(python3 - "$workdir" <<'PY'
import os, sys
print(os.path.realpath(sys.argv[1]))
PY
)
  normalized_project_dir=$(python3 - "$project_dir" <<'PY'
import os, sys
print(os.path.realpath(sys.argv[1]))
PY
)

  while IFS= read -r session_id; do
    [ -n "$session_id" ] || continue
    session_dir=$(resolve_session_directory "$session_id" || true)
    [ -n "$session_dir" ] || continue
    normalized_session_dir=$(python3 - "$session_dir" <<'PY'
import os, sys
print(os.path.realpath(sys.argv[1]))
PY
)
    if [ "$normalized_session_dir" = "$normalized_workdir" ] || [ "$normalized_session_dir" = "$normalized_project_dir" ]; then
      printf '%s\n' "$session_id"
      return 0
    fi
  done <<EOF
$candidates
EOF

  return 1
}

get_latest_storage_session_id_since() {
  local timestamp_file="$1"
  local storage_dir
  storage_dir=$(get_storage_session_diff_dir)

  if [ ! -d "$storage_dir" ]; then
    return 1
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$storage_dir" "$timestamp_file" <<'PY'
import os
import sys

storage_dir, timestamp_file = sys.argv[1:3]

try:
    threshold = os.path.getmtime(timestamp_file)
except OSError:
    raise SystemExit(1)

latest = None
latest_mtime = -1.0

for entry in os.scandir(storage_dir):
    if not entry.is_file() or not entry.name.endswith('.json'):
        continue
    try:
        mtime = entry.stat().st_mtime
    except OSError:
        continue
    if mtime <= threshold:
        continue
    if mtime > latest_mtime:
        latest_mtime = mtime
        latest = entry.name[:-5]

if latest:
    print(latest)
PY
    return 0
  fi

  return 1
}

get_latest_transcript_session_id_since() {
  local timestamp_file="$1"
  local transcripts_dir
  transcripts_dir=$(get_transcripts_dir)

  if [ ! -d "$transcripts_dir" ]; then
    return 1
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$transcripts_dir" "$timestamp_file" <<'PY'
import os
import sys

transcripts_dir, timestamp_file = sys.argv[1:3]

try:
    threshold = os.path.getmtime(timestamp_file)
except OSError:
    raise SystemExit(1)

latest = None
latest_mtime = -1.0

for entry in os.scandir(transcripts_dir):
    if not entry.is_file() or not entry.name.endswith('.jsonl'):
        continue
    try:
        mtime = entry.stat().st_mtime
    except OSError:
        continue
    if mtime <= threshold:
        continue
    if mtime > latest_mtime:
        latest_mtime = mtime
        latest = entry.name[:-6]

if latest:
    print(latest)
PY
    return 0
  fi

  return 1
}

main_prompt_requests_ignore_memory() {
  if [ "${1:-}" != "run" ]; then
    return 1
  fi

  local joined
  joined=$(printf '%s\n' "$*" | tr '[:upper:]' '[:lower:]')
  printf '%s\n' "$joined" | grep -Eq "(ignore|don't use|do not use|without|skip)[[:space:]]+(the[[:space:]]+)?memory|memory[[:space:]]+((should|must)[[:space:]]+be[[:space:]]+)?ignored"
}

wait_for_scoped_session_id_since() {
  local before_json="$1"
  local started_at_ms="$2"
  local timestamp_file="$3"
  local wait_seconds="${4:-5}"
  local allow_existing_fallback="${5:-1}"
  local attempt=0
  local session_id=""

  while [ "$attempt" -lt "$wait_seconds" ]; do
    session_id=$(get_session_target_id "$before_json" "$started_at_ms" "$WORKING_DIR" "$PROJECT_SCOPE_DIR" "$allow_existing_fallback" || true)
    if [ -z "$session_id" ]; then
      session_id=$(get_scoped_artifact_session_id_since "$timestamp_file" "$WORKING_DIR" "$PROJECT_SCOPE_DIR" || true)
    fi
    if [ -n "$session_id" ]; then
      printf '%s\n' "$session_id"
      return 0
    fi
    sleep 1
    attempt=$((attempt + 1))
  done

  return 1
}

wait_for_session_target_id() {
  local before_json="$1"
  local started_at_ms="$2"
  local wait_seconds="${3:-5}"

  wait_for_scoped_session_id_since "$before_json" "$started_at_ms" "$TIMESTAMP_FILE" "$wait_seconds"
}

get_fork_cleanup_candidate_id() {
  local started_at_ms="$1"
  local parent_title="$2"
  local workdir="$3"
  local project_dir="$4"
  local db_path
  db_path=$(get_opencode_db_path)

  if [ -z "$started_at_ms" ] || [ -z "$parent_title" ] || [ ! -f "$db_path" ] || ! command -v python3 >/dev/null 2>&1; then
    return 1
  fi

  python3 - "$db_path" "$started_at_ms" "$parent_title" "$workdir" "$project_dir" <<'PY'
import os
import re
import sqlite3
import sys

db_path, started_at_ms_raw, parent_title, workdir, project_dir = sys.argv[1:6]
started_at_ms = int(started_at_ms_raw or "0")
scope = {os.path.realpath(path) for path in (workdir, project_dir) if path}
title_pattern = re.compile(rf"^{re.escape(parent_title)} \(fork #\d+\)$")

try:
    conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    rows = conn.execute(
        "SELECT id, title, directory, time_created FROM session WHERE time_created >= ? ORDER BY time_created DESC",
        (started_at_ms,),
    ).fetchall()
except Exception:
    raise SystemExit(1)
finally:
    try:
        conn.close()
    except Exception:
        pass

matches = []
for session_id, title, directory, time_created in rows:
    if not session_id or not title or not directory or not time_created:
        continue
    if os.path.realpath(directory) not in scope:
        continue
    if not title_pattern.match(title):
        continue
    matches.append(session_id)

if len(matches) == 1:
    print(matches[0])
PY
}

wait_for_fork_cleanup_candidate_id() {
  local started_at_ms="$1"
  local parent_title="$2"
  local wait_seconds="${3:-5}"
  local attempt=0
  local session_id=""

  while [ "$attempt" -lt "$wait_seconds" ]; do
    session_id=$(get_fork_cleanup_candidate_id "$started_at_ms" "$parent_title" "$WORKING_DIR" "$PROJECT_SCOPE_DIR" || true)
    if [ -n "$session_id" ]; then
      printf '%s\n' "$session_id"
      return 0
    fi
    sleep 1
    attempt=$((attempt + 1))
  done

  return 1
}

file_mtime_secs() {
  local file="$1"
  if [ ! -f "$file" ]; then
    echo 0
    return 0
  fi

  if stat -c %Y "$file" >/dev/null 2>&1; then
    stat -c %Y "$file"
    return 0
  fi

  stat -f %m "$file"
}

# Claude-style lock/mtime semantics:
# - lock file CONTENT (PID) = current holder
# - lock file MTIME = last successful consolidation timestamp
read_last_consolidated_at_secs() {
  file_mtime_secs "$CONSOLIDATION_LOCK_FILE"
}

set_file_mtime_secs() {
  local file="$1"
  local secs="$2"

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$file" "$secs" <<'PY'
import os
import sys

path = sys.argv[1]
secs = int(sys.argv[2])
os.utime(path, (secs, secs))
PY
    return 0
  fi

  # Best effort fallback; may not be portable across all environments.
  touch -d "@$secs" "$file" >/dev/null 2>&1 || true
}

acquire_simple_lock() {
  local lock_file="$1"
  local lock_name="$2"

  if [ -f "$lock_file" ]; then
    local lock_pid
    lock_pid=$(cat "$lock_file" 2>/dev/null || true)
    if [ -n "$lock_pid" ] && kill -0 "$lock_pid" 2>/dev/null; then
      log "Another $lock_name is already running (PID $lock_pid), skipping"
      return 1
    fi
    rm -f "$lock_file"
  fi

  echo $$ > "$lock_file"
  return 0
}

release_simple_lock() {
  local lock_file="$1"
  rm -f "$lock_file"
}

count_sessions_touched_since_ms() {
  local since_ms="$1"
  local exclude_session_id="$2"

  if ! command -v jq >/dev/null 2>&1; then
    echo ""
    return 1
  fi

  local session_json
  session_json=$(get_session_list_json "$AUTODREAM_SCAN_LIMIT") || {
    echo ""
    return 1
  }

  echo "$session_json" | jq -r --argjson since "$since_ms" --arg exclude "$exclude_session_id" '
    [ .[]
      | select((.id // "") != $exclude)
      | select(((.time.updated // .time.created // 0) | tonumber) > $since)
    ] | length
  '
}

CONSOLIDATION_PRIOR_MTIME=0

try_acquire_consolidation_lock() {
  local path="$CONSOLIDATION_LOCK_FILE"
  local now mtime holder age

  # Returns prior mtime via CONSOLIDATION_PRIOR_MTIME so callers can rollback
  # on failure (preserving last successful consolidation time semantics).

  now=$(date +%s)
  mtime=0
  holder=""

  if [ -f "$path" ]; then
    mtime=$(file_mtime_secs "$path")
    holder=$(cat "$path" 2>/dev/null || true)
    age=$((now - mtime))

    if [ "$age" -lt "$AUTODREAM_STALE_LOCK_SECS" ] && [ -n "$holder" ] && kill -0 "$holder" 2>/dev/null; then
      log "Auto-dream lock held by live PID $holder (${age}s old), skipping"
      return 1
    fi
  fi

  mkdir -p "$(dirname "$path")"
  echo $$ > "$path"

  local verify
  verify=$(cat "$path" 2>/dev/null || true)
  if [ "$verify" != "$$" ]; then
    return 1
  fi

  CONSOLIDATION_PRIOR_MTIME="$mtime"
  return 0
}

rollback_consolidation_lock() {
  local prior_mtime="$1"
  local path="$CONSOLIDATION_LOCK_FILE"

  if [ "$prior_mtime" -eq 0 ]; then
    rm -f "$path"
    return 0
  fi

  : > "$path"
  set_file_mtime_secs "$path" "$prior_mtime"
}

cleanup_forked_sessions() {
  local started_at_ms="$1"
  local parent_title="$2"

  if [ -z "$started_at_ms" ] || [ -z "$parent_title" ]; then
    return 0
  fi

  if ! command -v python3 >/dev/null 2>&1; then
    return 0
  fi

  if ! python3 - <<'PY' >/dev/null 2>&1
pass
PY
  then
    return 0
  fi

  local fork_id
  fork_id=$(wait_for_fork_cleanup_candidate_id "$started_at_ms" "$parent_title" "$SESSION_WAIT_SECONDS" || true)

  [ -n "$fork_id" ] || return 0

  if "$REAL_OPENCODE" session delete "$fork_id" >/dev/null 2>&1; then
    log "Cleaned up forked session $fork_id"
  fi
}

session_has_conversation() {
  local session_id="$1"
  local transcript_file
  transcript_file="$(get_transcripts_dir)/${session_id}.jsonl"

  if [ -f "$transcript_file" ]; then
    local line_count
    line_count=$(wc -l < "$transcript_file")
    # Empty sessions have at most 1 line (the initial user entry with no content).
    # Real sessions have 3+ lines (user + tool_use + tool_result at minimum).
    [ "$line_count" -gt 1 ]
    return $?
  fi

  # Transcript not found — assume content exists to avoid skipping a valid session.
  return 0
}

transcript_fingerprint() {
  local transcript_file="$1"
  local stat_output

  if [ ! -f "$transcript_file" ]; then
    return 1
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$transcript_file" <<'PY'
import os
import sys

path = sys.argv[1]

try:
    file_stat = os.stat(path)
except OSError:
    raise SystemExit(1)

mtime = getattr(file_stat, "st_mtime_ns", int(file_stat.st_mtime * 1_000_000_000))
print(f"{file_stat.st_size}\t{mtime}")
PY
    return $?
  fi

  if stat_output=$(stat -f '%z	%m' "$transcript_file" 2>/dev/null); then
    printf '%s\n' "$stat_output"
    return 0
  fi

  if stat_output=$(stat -c '%s	%Y' "$transcript_file" 2>/dev/null); then
    printf '%s\n' "$stat_output"
    return 0
  fi

  return 1
}

write_transcript_checkpoint() {
  local output_file="$1"
  local transcripts_dir
  transcripts_dir="$(get_transcripts_dir)"

  : > "$output_file"
  [ -d "$transcripts_dir" ] || return 0

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$transcripts_dir" > "$output_file" <<'PY'
import os
import stat
import sys

transcripts_dir = sys.argv[1]

try:
    filenames = os.listdir(transcripts_dir)
except OSError:
    raise SystemExit(0)

for filename in filenames:
    if not filename.endswith(".jsonl"):
        continue
    path = os.path.join(transcripts_dir, filename)
    try:
        file_stat = os.stat(path)
    except OSError:
        continue
    if not stat.S_ISREG(file_stat.st_mode):
        continue
    session_id = filename[:-6]
    if not session_id:
        continue
    mtime = getattr(file_stat, "st_mtime_ns", int(file_stat.st_mtime * 1_000_000_000))
    print(f"{session_id}\t{file_stat.st_size}\t{mtime}")
PY
    return 0
  fi

  find "$transcripts_dir" -maxdepth 1 -type f -name '*.jsonl' -print 2>/dev/null | while IFS= read -r transcript_file; do
    local filename session_id fingerprint
    filename="$(basename "$transcript_file")"
    session_id="${filename%.jsonl}"
    fingerprint="$(transcript_fingerprint "$transcript_file" || true)"
    [ -n "$session_id" ] && [ -n "$fingerprint" ] || continue
    printf '%s\t%s\n' "$session_id" "$fingerprint"
  done > "$output_file"
}

read_transcript_checkpoint() {
  local session_id="$1"

  [ -f "$TRANSCRIPT_CHECKPOINT_FILE" ] || return 1
  awk -F '\t' -v id="$session_id" '$1 == id { print $2 "\t" $3; found=1; exit } END { exit found ? 0 : 1 }' "$TRANSCRIPT_CHECKPOINT_FILE"
}

session_has_incremental_activity() {
  local session_id="$1"
  local transcript_file previous current
  transcript_file="$(get_transcripts_dir)/${session_id}.jsonl"

  if [ -f "$transcript_file" ]; then
    current="$(transcript_fingerprint "$transcript_file" || true)"
    previous="$(read_transcript_checkpoint "$session_id" || true)"
    if [ -z "$previous" ]; then
      return 0
    fi
    [ "$current" != "$previous" ]
    return $?
  fi

  # If no transcript is available, keep the existing conservative behavior:
  # session_diff/session-list discovery may still have found a valid new turn.
  return 0
}

# ----------------------------------------------------------------------------
# Incremental extraction high-water marks
#
# After a session is extracted we persist how many USER turns the transcript held
# at that point. On a later resume we re-mine only the turns past that mark, and
# skip entirely when nothing new was said. The mark is the user-turn count because
# it is monotonic, cheap for the wrapper to compute, AND something the forked
# extractor can itself count in the conversation it sees — so the boundary note we
# inject ("turns 1..N already done") is one the model can actually apply.
# ----------------------------------------------------------------------------

EXTRACT_MARKS_DIR="$STATE_DIR/extract-marks"

count_user_turns() {
  # Echoes the number of `type:"user"` entries in a session transcript, or nothing
  # if it cannot be determined (caller must treat "unknown" as fail-safe = full).
  local transcript_file="$1"
  [ -f "$transcript_file" ] || return 1

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$transcript_file" <<'PY'
import json, sys
path = sys.argv[1]
n = 0
try:
    with open(path, encoding="utf-8") as fh:
        for line in fh:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except Exception:
                continue
            kind = obj.get("type")
            if kind is None and isinstance(obj.get("message"), dict):
                kind = obj["message"].get("role")
            if kind == "user":
                n += 1
except OSError:
    raise SystemExit(1)
print(n)
PY
    return $?
  fi

  # No python3: a grep over raw JSONL would also match `"role":"user"` embedded in
  # pasted/discussed content and over-count. Rather than risk a wrong (too-high)
  # mark that silently skips real turns, report "unknown" so the caller does a
  # full extraction. (python3 is already required by the rest of the wrapper.)
  return 1
}

read_extract_mark() {
  local mark_file="$EXTRACT_MARKS_DIR/$1"
  [ -f "$mark_file" ] || return 1
  local value
  value=$(head -1 "$mark_file" 2>/dev/null | tr -dc '0-9')
  # Reject empty or absurdly long values: a >15-digit count would overflow bash
  # arithmetic in the `-eq`/`-lt` comparisons and abort under set -e.
  [ -n "$value" ] && [ "${#value}" -le 15 ] || return 1
  printf '%s\n' "$value"
}

write_extract_mark() {
  local session_id="$1" turns="$2"
  [ "$INCREMENTAL_ENABLED" = "0" ] && return 0
  [[ "$turns" =~ ^[0-9]+$ ]] || return 0
  mkdir -p "$EXTRACT_MARKS_DIR" 2>/dev/null || return 0
  printf '%s\n' "$turns" > "$EXTRACT_MARKS_DIR/$session_id" 2>/dev/null || true
  # Bound unbounded growth: marks are tiny, but prune ones untouched for 90 days.
  find "$EXTRACT_MARKS_DIR" -maxdepth 1 -type f -mtime +90 -delete 2>/dev/null || true
}

run_extraction_if_needed() {
  local session_id="$1"
  local memory_written_during_session="$2"

  if [ "$EXTRACT_ENABLED" = "0" ]; then
    return 0
  fi

  # Current user-turn count drives the incremental marks below. Empty => unknown
  # (no transcript / parse failure) => fall back to non-incremental behavior.
  local current_turns=""
  if [ "$INCREMENTAL_ENABLED" != "0" ]; then
    current_turns=$(count_user_turns "$(get_transcripts_dir)/${session_id}.jsonl" 2>/dev/null || true)
    [[ "$current_turns" =~ ^[0-9]+$ ]] || current_turns=""
  fi

  if [ "$memory_written_during_session" = "1" ]; then
    log "Main agent already wrote memories during session, skipping extraction"
    # Do NOT advance the mark here: has_new_memories() is not session/project
    # scoped (it sees any memory write under ~/.claude/projects), so a write in
    # another project would falsely advance this session's mark and permanently
    # skip turns. Leaving the mark unchanged means a later forked extraction
    # re-diffs from the last real extraction; EXTRACT_PROMPT dedups via MEMORY.md.
    return 0
  fi

  # Incremental gate. The mark is a monotonic high-water mark of user turns.
  #   current == mark : nothing new said -> skip.
  #   current >  mark : re-mine only the delta (inject a boundary note).
  #   current <  mark : transcript shrank (compaction / reset) -> the mark is
  #                     stale; do a FULL extraction and let success re-baseline
  #                     it, rather than skipping forever.
  local prev_turns="" incremental_block=""
  if [ -n "$current_turns" ]; then
    prev_turns=$(read_extract_mark "$session_id" || true)
    if [ -n "$prev_turns" ]; then
      if [ "$current_turns" -eq "$prev_turns" ]; then
        log "Incremental: session $session_id has no new user turns since last extraction (mark $prev_turns), skipping"
        return 0
      elif [ "$current_turns" -lt "$prev_turns" ]; then
        log "Incremental: transcript shrank ($current_turns < mark $prev_turns); treating mark as stale, full extraction"
      else
        local delta=$((current_turns - prev_turns))
        incremental_block="INCREMENTAL EXTRACTION: a prior extraction pass already processed user turns 1-${prev_turns} of this conversation and saved any memories they warranted. Treat those earlier turns as already-extracted CONTEXT — do NOT re-emit memories for them. Mine ONLY the ${delta} new user turn(s) after turn ${prev_turns} for NEW durable memories (you may still read the earlier turns for context). If the new turns warrant nothing, save nothing."
        log "Incremental: re-mining $delta new user turn(s) since mark $prev_turns (now $current_turns)"
      fi
    fi
  fi

  if ! acquire_simple_lock "$EXTRACT_LOCK_FILE" "memory extraction"; then
    return 0
  fi

  log "Extracting memories from session $session_id..."
  log "Extraction log: $EXTRACT_LOG_FILE"

  local parent_session_title
  parent_session_title=$(get_session_title_from_db "$session_id" || true)

  local cmd=("$REAL_OPENCODE" run -s "$session_id" --fork --dir "$WORKING_DIR")
  if [ -n "$EXTRACT_MODEL" ]; then
    cmd+=(-m "$EXTRACT_MODEL")
  fi
  if [ -n "$EXTRACT_AGENT" ]; then
    cmd+=(--agent "$EXTRACT_AGENT")
  fi

  # Prepend recovered commit-hash provenance to the extract prompt (opt-out via
  # OPENCODE_MEMORY_PROVENANCE=0). file:line provenance needs nothing extra — the
  # fork already replays the real tool calls.
  local commits_block=""
  if [ "${OPENCODE_MEMORY_PROVENANCE:-1}" != "0" ]; then
    commits_block=$(get_session_commits_block "$session_id" "$WORKING_DIR" 2>/dev/null || true)
  fi
  # Compose the final prompt from the optional incremental + commit prefixes and
  # the base EXTRACT_PROMPT, joined by blank lines (only non-empty parts appear).
  local full_prompt="$EXTRACT_PROMPT"
  if [ -n "$commits_block" ]; then
    full_prompt="${commits_block}"$'\n\n'"$full_prompt"
    log "Injected commit provenance ($(printf '%s\n' "$commits_block" | grep -c '^- ') commits)"
  fi
  if [ -n "$incremental_block" ]; then
    full_prompt="${incremental_block}"$'\n\n'"$full_prompt"
  fi
  cmd+=("$full_prompt")

  local fork_started_at_ms
  fork_started_at_ms=$(( $(date +%s) * 1000 ))

  if "${cmd[@]}" >> "$EXTRACT_LOG_FILE" 2>&1; then
    log "Memory extraction completed successfully"
    # Advance the high-water mark only on success; a failed run leaves the mark so
    # the same delta is retried next time.
    [ -n "$current_turns" ] && write_extract_mark "$session_id" "$current_turns"
  else
    local code=$?
    log "Memory extraction failed (exit code $code). Check $EXTRACT_LOG_FILE for details"
  fi

  cleanup_forked_sessions "$fork_started_at_ms" "$parent_session_title"
  release_simple_lock "$EXTRACT_LOCK_FILE"
}

run_autodream_if_needed() {
  local session_id="$1"

  if [ "$AUTODREAM_ENABLED" = "0" ]; then
    return 0
  fi

  if ! command -v jq >/dev/null 2>&1; then
    log "jq not found, skipping auto-dream (requires JSON session parsing)"
    return 0
  fi

  local last_at now hours_since since_ms touched_count
  last_at=$(read_last_consolidated_at_secs)
  now=$(date +%s)

  hours_since=$(((now - last_at) / 3600))
  if [ "$hours_since" -lt "$AUTODREAM_MIN_HOURS" ]; then
    return 0
  fi

  since_ms=$((last_at * 1000))
  touched_count=$(count_sessions_touched_since_ms "$since_ms" "$session_id" || true)
  if [ -z "$touched_count" ]; then
    log "Unable to inspect touched sessions, skipping auto-dream"
    return 0
  fi

  if [ "$touched_count" -lt "$AUTODREAM_MIN_SESSIONS" ]; then
    return 0
  fi

  if ! try_acquire_consolidation_lock; then
    return 0
  fi

  log "Auto-dream firing (${hours_since}h since last consolidation, ${touched_count} sessions touched)"
  log "Auto-dream log: $AUTODREAM_LOG_FILE"

  local parent_session_title
  parent_session_title=$(get_session_title_from_db "$session_id" || true)

  local cmd=("$REAL_OPENCODE" run -s "$session_id" --fork --dir "$WORKING_DIR")
  if [ -n "$AUTODREAM_MODEL" ]; then
    cmd+=(-m "$AUTODREAM_MODEL")
  fi
  if [ -n "$AUTODREAM_AGENT" ]; then
    cmd+=(--agent "$AUTODREAM_AGENT")
  fi
  cmd+=("$AUTODREAM_PROMPT")

  local fork_started_at_ms
  fork_started_at_ms=$(( $(date +%s) * 1000 ))

  if "${cmd[@]}" >> "$AUTODREAM_LOG_FILE" 2>&1; then
    log "Auto-dream consolidation completed successfully"
    # Keep lock mtime at "now" to represent last consolidated timestamp.
  else
    local code=$?
    log "Auto-dream consolidation failed (exit code $code). Rolling back gate timestamp"
    rollback_consolidation_lock "$CONSOLIDATION_PRIOR_MTIME"
  fi

  cleanup_forked_sessions "$fork_started_at_ms" "$parent_session_title"
}

run_post_session_tasks() {
  local session_id="$1"
  local memory_written_during_session="$2"

  run_extraction_if_needed "$session_id" "$memory_written_during_session"
  run_autodream_if_needed "$session_id"
}

run_post_session_for_invocation() {
  local session_id
  local memory_written_during_session

  # Capture the session ID for this invocation. In background mode this wait
  # must not delay the visible exit of the wrapped opencode process.
  session_id=$(wait_for_session_target_id "$PRE_SESSION_JSON" "$SESSION_CAPTURE_STARTED_AT_MS" "$SESSION_WAIT_SECONDS" || true)
  if [ -z "$session_id" ]; then
    log "No session found, skipping post-session memory maintenance"
    cleanup_timestamp
    return 0
  fi

  # Skip if session had no real conversation (e.g. user opened TUI and exited).
  if ! session_has_conversation "$session_id"; then
    log "Session $session_id has no conversation, skipping post-session memory maintenance"
    cleanup_timestamp
    return 0
  fi

  if ! session_has_incremental_activity "$session_id"; then
    log "Session $session_id has no new transcript activity, skipping post-session memory maintenance"
    cleanup_timestamp
    return 0
  fi

  memory_written_during_session=0
  if has_new_memories; then
    memory_written_during_session=1
  fi

  # Timestamp file is no longer needed after the check above.
  cleanup_timestamp

  run_post_session_tasks "$session_id" "$memory_written_during_session"
}

run_maintain() {
  # Process the latest in-scope session for WORKING_DIR (no interactive run).
  # The on_close hook fires right after a session ends, so the newest in-scope
  # session is normally the one just closed. Caveats: (1) if a SECOND session in
  # the same dir/project is still live and more recently updated, that one is
  # picked instead — acceptable for the single-tile-per-project common case;
  # (2) memory_written is forced to 0 (a bare-binary tile was never tracked), so
  # repeated maintain on the same session re-extracts and relies on the extractor
  # deduping against MEMORY.md (plus the incremental high-water mark when a
  # transcript mirror is present).
  # Resolve with a short retry: on_close fires right after SIGTERM, so the
  # session may need a beat to appear in `session list`.
  local session_id="" tries=0
  while [ "$tries" -lt 5 ]; do
    session_id=$(get_session_target_id "[]" 0 "$WORKING_DIR" "$PROJECT_SCOPE_DIR" 1 || true)
    [ -n "$session_id" ] && break
    tries=$((tries + 1))
    sleep 1
  done
  if [ -z "$session_id" ]; then
    log "maintain: no session found for $WORKING_DIR, nothing to do"
    return 0
  fi
  if ! session_has_conversation "$session_id"; then
    log "maintain: session $session_id has no conversation, skipping"
    return 0
  fi
  # Let opencode flush its final turns to the DB before we fork the session
  # (the caller may have just SIGTERM'd it). Tunable; 0 disables.
  local settle="${OPENCODE_MEMORY_MAINTAIN_SETTLE:-2}"
  case "$settle" in ''|*[!0-9]*) settle=2 ;; esac
  [ "$settle" -gt 0 ] && sleep "$settle"
  log "maintain: processing latest session $session_id for $WORKING_DIR"
  run_post_session_tasks "$session_id" 0
}

# ============================================================================
# Main
# ============================================================================

# Maintenance-only mode (`opencode-memory maintain`): skip the interactive run
# and process the latest session directly. Runs in the foreground so a caller
# (cron, the dashboard on_close hook) can wait for completion.
if [ "${MAINTAIN_MODE:-0}" = "1" ]; then
  run_maintain
  exit 0
fi

# Step 0: Create timestamp marker before running opencode
TIMESTAMP_FILE=$(mktemp)
TRANSCRIPT_CHECKPOINT_FILE=$(mktemp)
write_transcript_checkpoint "$TRANSCRIPT_CHECKPOINT_FILE"
SESSION_CAPTURE_STARTED_AT_MS=$(( $(date +%s) * 1000 ))
PRE_SESSION_JSON=$(get_session_list_json "$AUTODREAM_SCAN_LIMIT" 2>/dev/null || true)

# Step 1: Run the real opencode with all original arguments, capture exit code
opencode_exit=0
if main_prompt_requests_ignore_memory "$@"; then
  OPENCODE_MEMORY_IGNORE=1 "$REAL_OPENCODE" "$@" || opencode_exit=$?
else
  "$REAL_OPENCODE" "$@" || opencode_exit=$?
fi

# Step 2: If no maintenance task is enabled, exit early
if [ "$EXTRACT_ENABLED" = "0" ] && [ "$AUTODREAM_ENABLED" = "0" ]; then
  cleanup_timestamp
  exit $opencode_exit
fi

# Step 3: Run post-session maintenance (foreground for debug, background by default).
if [ "$FOREGROUND" = "1" ]; then
  run_post_session_for_invocation
else
  run_post_session_for_invocation &
  disown
  log "Post-session memory maintenance started in background (PID $!)"
fi

exit $opencode_exit
